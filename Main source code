	if s then tw(s,0.20,{Position=UDim2.new(1,0,0,0)},Enum.EasingStyle.Quad,Enum.EasingDirection.In) end
	HS.Position=UDim2.new(-0.36,0,0,0); tw(HS,0.28,{Position=UDim2.new(0,0,0,0)})
	task.delay(0.24,function() if s then s.Visible=false end end)
end
mkB(Screen,UDim2.new(1,0,0.08,0),UDim2.new(0,0,0.92,0),26).MouseButton1Click:Connect(function()
	if currentApp then goHome() end
end)

