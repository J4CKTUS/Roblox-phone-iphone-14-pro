-- ── HELPERS ──────────────────────────────────────────────────────────
local function tw(o,t,p,s,d)
	TweenService:Create(o,TweenInfo.new(t,s or Enum.EasingStyle.Quart,d or Enum.EasingDirection.Out),p):Play()
end
local function twB(o,t,p) tw(o,t,p,Enum.EasingStyle.Back,Enum.EasingDirection.Out) end
local function mkF(parent,size,pos,col,alpha,zi,name,clip)
	local f=Instance.new("Frame"); f.Size=size; f.Position=pos or UDim2.new(0,0,0,0)
	f.BackgroundColor3=col or Color3.new(0,0,0); f.BackgroundTransparency=alpha or 0
	f.BorderSizePixel=0; f.ZIndex=zi or 1; f.Name=name or "F"; f.ClipsDescendants=clip or false
	f.Parent=parent; return f
end
local function mkR(obj,s) local c=Instance.new("UICorner"); c.CornerRadius=UDim.new(s or 1,0); c.Parent=obj; return c end
local function mkG(obj,c0,c1,rot) local g=Instance.new("UIGradient"); g.Color=ColorSequence.new(c0,c1); g.Rotation=rot or 180; g.Parent=obj end
local function mkL(parent,txt,size,pos,col,font,zi,ax)
	local l=Instance.new("TextLabel"); l.Size=size; l.Position=pos or UDim2.new(0,0,0,0)
	l.BackgroundTransparency=1; l.Text=txt; l.TextColor3=col or Color3.new(1,1,1)
	l.Font=font or Enum.Font.GothamBold; l.TextScaled=true; l.BorderSizePixel=0
	l.ZIndex=zi or 1; l.TextXAlignment=ax or Enum.TextXAlignment.Center
	l.TextTruncate=Enum.TextTruncate.AtEnd; l.Parent=parent; return l
end
local function mkB(parent,size,pos,zi)
	local b=Instance.new("TextButton"); b.Size=size; b.Position=pos or UDim2.new(0,0,0,0)
	b.BackgroundTransparency=1; b.Text=""; b.BorderSizePixel=0; b.ZIndex=zi or 1
	b.AutoButtonColor=false; b.Parent=parent; return b
end

-- Invisible watermark label (transparent, size 0 — not visible in game)
local function mkWM(parent,txt,zi)
	local l=Instance.new("TextLabel"); l.Size=UDim2.new(0,0,0,0)
	l.BackgroundTransparency=1; l.TextTransparency=1; l.Text=txt
	l.Font=Enum.Font.Gotham; l.TextScaled=false; l.TextSize=1
	l.BorderSizePixel=0; l.ZIndex=zi or 1; l.Name="_wm"
	l.Parent=parent; return l
end

