-- ── PHONE OPEN / CLOSE ───────────────────────────────────────────────
local function openPhone()
	phoneOpen=true; isLocked=true
	for _,s in pairs(appScreens) do s.Visible=false; s.Position=UDim2.new(1,0,0,0) end
	currentApp=nil; LS.Visible=true; LS.Position=UDim2.new(0,0,0,0)
	HS.Visible=false; HS.Position=UDim2.new(0,0,0,0)
	PC.Visible=true; PC.Position=POS_CLOSE; twB(PC,0.50,{Position=POS_OPEN})
end
local function closePhone()
	phoneOpen=false
	tw(PC,0.32,{Position=POS_CLOSE},Enum.EasingStyle.Back,Enum.EasingDirection.In)
	task.delay(0.34,function() if not phoneOpen then PC.Visible=false end end)
end
UserInputService.InputBegan:Connect(function(inp,proc)
	if proc then return end
	if inp.KeyCode==Enum.KeyCode.M then if phoneOpen then closePhone() else openPhone() end end
end)

